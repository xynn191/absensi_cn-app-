APP_NAME=Absensi CN API
APP_ENV=production
APP_PORT=8080
API_PREFIX=/api/v1
APP_ALLOWED_ORIGINS=http://localhost:3000

DB_ENABLED=false
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=absensi_cn
DB_USER=root
DB_PASSWORD=
DB_PARAMS=charset=utf8mb4&parseTime=True&loc=Local

JWT_SECRET=replace-with-secure-secret
JWT_EXPIRES_IN_HOURS=24
